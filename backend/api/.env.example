# Sovereign Compute Engine — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Nomad server address
NOMAD_ADDR=http://127.0.0.1:4646

# Nomad ACL token (leave empty for dev mode)
NOMAD_TOKEN=

# CORS origins (comma-separated) — add your Next.js dashboard URL
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080

# API server settings
API_HOST=0.0.0.0
API_PORT=8080
